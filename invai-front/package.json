{
  "name": "invai-front",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config=proxy.dev.conf.json",
    "start-es": "ng serve --configuration=development-es --proxy-config=proxy.dev.conf.json",
    "local": "ng serve --proxy-config=proxy.local.conf.json",
    "local-es": "ng serve --configuration=development-es --proxy-config=proxy.local.conf.json",
    "build:dev": "ng build --configuration=development",
    "build:production": "ng build --configuration=production",
    "build:ca": "ng build --configuration=production,ca",
    "build:es": "ng build --configuration=production,es",
    "build:i18n": "ng build --configuration=production --localize",
    "preview:i18n": "npm run build:i18n && live-server dist/invai_front/browser --mount=/invaifront:dist/invai_front/browser --open=/invaifront/ca/",
    "i18n": "ng extract-i18n --format xlf --output-path src/locale --out-file messages.xml",
    "watch": "ng build --watch --configuration=development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.3.0",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@primeuix/styles": "^2.0.3",
    "@primeuix/themes": "^2.0.3",
    "github-markdown-css": "^5.9.0",
    "ngx-markdown": "^21.1.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/localize": "^21.1.5",
    "@tailwindcss/postcss": "^4.1.12",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
